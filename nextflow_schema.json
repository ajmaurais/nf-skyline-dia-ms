{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/nf-skyline-dia-ms//nextflow_schema.json",
  "title": "nf-skyline-dia-ms pipeline parameters",
  "description": "DIA workflows for TEI-REX project",
  "type": "object",
  "properties": {
    "quant_spectra_dir": {
      "type": "string",
      "default": "[batch_1:'/path/to/dir']"
    },
    "quant_spectra_glob": {
      "type": "string",
      "default": "*.raw"
    },
    "chromatogram_library_spectra_dir": {
      "type": "string"
    },
    "chromatogram_library_spectra_glob": {
      "type": "string",
      "default": "*.raw"
    },
    "spectral_library": {
      "type": "string"
    },
    "fasta": {
      "type": "string"
    },
    "files_per_quant_batch": {
      "type": "string"
    },
    "files_per_chrom_lib": {
      "type": "string"
    },
    "random_file_seed": {
      "type": "integer",
      "default": 12
    },
    "use_vendor_raw": {
      "type": "boolean"
    },
    "skyline_document_name": {
      "type": "string"
    },
    "skyline_template_file": {
      "type": "string"
    },
    "skip_skyline": {
      "type": "string"
    },
    "skyline_skyr_file": {
      "type": "string"
    },
    "search_engine": {
      "type": "string",
      "default": "encyclopedia"
    },
    "email": {
      "type": "string"
    },
    "panorama_upload": {
      "type": "boolean"
    },
    "msconvert_only": {
      "type": "boolean"
    },
    "replicate_metadata": {
      "type": "string"
    },
    "result_dir": {
      "type": "string",
      "default": "results/nf-skyline-dia-ms"
    },
    "report_dir": {
      "type": "string",
      "default": "reports/nf-skyline-dia-ms"
    },
    "default_skyline_template_file": {
      "type": "string",
      "default": "https://github.com/mriffle/nf-skyline-dia-ms/raw/main/resources/template.sky.zip"
    },
    "max_memory": {
      "type": "string",
      "default": "12.GB"
    },
    "max_cpus": {
      "type": "integer",
      "default": 8
    },
    "max_time": {
      "type": "string",
      "default": "240.h"
    },
    "mzml_cache_directory": {
      "type": "string",
      "default": "/data/mass_spec/nextflow/nf-skyline-dia-ms/mzml_cache"
    },
    "panorama_cache_directory": {
      "type": "string",
      "default": "/data/mass_spec/nextflow/panorama/raw_cache"
    },
    "images": {
      "type": "string",
      "default": "[ubuntu:'ubuntu:22.04', diann:'quay.io/protio/diann:1.8.1', bibliospec:'quay.io/protio/bibliospec-linux:3.0', panorama_client:'quay.io/protio/panorama-client:1.1.0', pdc_client:'quay.io/mauraisa/pdc_client:2.2.0', encyclopedia:'quay.io/protio/encyclopedia:2.12.30-2', encyclopedia3_mriffle:'quay.io/protio/encyclopedia:3.0.0-MRIFFLE', qc_pipeline:'quay.io/mauraisa/dia_qc_report:2.4.3', proteowizard:'quay.io/mauraisa/pwiz-skyline-i-agree-to-the-vendor-licenses:skyline_daily_25.0.9.97-ae4c997', cascadia:'quay.io/protio/cascadia:0.0.7', cascadia_utils:'quay.io/protio/cascadia-utils:0.0.4', carafe:'quay.io/mauraisa/carafe:0.0.1-beta']"
    },
    "output_directories": {
      "type": "string",
      "default": "[panorama:'results/nf-skyline-dia-ms/panorama', aws:'results/nf-skyline-dia-ms/aws', msconvert:'results/nf-skyline-dia-ms/msconvert', diann:'results/nf-skyline-dia-ms/diann', cascadia:'results/nf-skyline-dia-ms/cascadia', qc_report:'results/nf-skyline-dia-ms/qc_report', qc_report_tables:'results/nf-skyline-dia-ms/qc_report/tables', batch_report:'results/nf-skyline-dia-ms/batch_report', batch_report_tables:'results/nf-skyline-dia-ms/batch_report/tables', batch_report_plots:'results/nf-skyline-dia-ms/batch_report/plots', gene_reports:'results/nf-skyline-dia-ms/gene_reports', encyclopedia:[convert_blib:'results/nf-skyline-dia-ms/encyclopedia/convert-blib', search_file:'results/nf-skyline-dia-ms/encyclopedia/search-file', create_elib:'results/nf-skyline-dia-ms/encyclopedia/create-elib'], skyline:[add_lib:'results/nf-skyline-dia-ms/skyline/add-lib', import_spectra:'results/nf-skyline-dia-ms/skyline/import-spectra', minimize:'results/nf-skyline-dia-ms/skyline/minimize', reports:'results/nf-skyline-dia-ms/skyline/reports']]"
    }
  }
}
